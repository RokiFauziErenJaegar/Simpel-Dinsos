# File yang tidak perlu di dalam image Docker untuk Railway

# Dependencies (akan di-install ulang di Dockerfile)
/node_modules
/vendor

# Local env & secrets (di Railway pakai env var dari dashboard)
.env
.env.backup
.env.production
.env.local
*.env

# Build artifact lokal
/public/build
/public/hot
/public/storage

# Database lokal — JANGAN ikut di-bundle ke production
/database/database.sqlite
/database/database.sqlite.backup-*
/database/*.sqlite-journal

# Storage lokal (di Railway pakai Volume)
/storage/app/public/*
/storage/app/secure/*
/storage/app/private/*
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/framework/testing/*
!/storage/app/.gitignore
!/storage/app/public/.gitignore
!/storage/logs/.gitignore
!/storage/framework/.gitignore
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/views/.gitignore

# Filament cache lokal
/bootstrap/cache/*.php
!/bootstrap/cache/.gitignore

# Git
/.git
/.gitignore
/.gitattributes
/.github

# IDE & editor
/.vscode
/.idea
/.fleet
*.swp
*.swo
*.sublime-*
.DS_Store
Thumbs.db

# Test & docs (opsional — comment kalau perlu dibawa)
/tests
/phpunit.xml
/phpunit.xml.dist
/.phpunit.result.cache
# Tetap bawa docs/ untuk akses runtime kalau dibutuhkan
# /docs

# Dev container / docker compose lain
/infra/docker-compose.minio.yml
/Dockerfile.local
/docker-compose.yml
/docker-compose.override.yml

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db

# Mobile starter (kalau ada folder mobile/flutter)
/mobile

# Backup file dari editor
*~
*.bak
*.tmp
*.orig
