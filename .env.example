APP_NAME="SIMPEL DINSOS Pringsewu"
APP_ENV=local
APP_KEY=
# PRODUKSI: APP_ENV=production, APP_DEBUG=false, APP_URL=https://<domain-anda>
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# PRODUKSI: LOG_LEVEL=warning (atau error), LOG_CHANNEL=stderr utk Railway
LOG_LEVEL=debug

# Database — PRODUKSI pakai mysql
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simpel_dinsos
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUKSI (HTTPS): wajib true agar cookie sesi aman
SESSION_SECURE_COOKIE=false

# log | reverb | pusher. Real-time TV antrian butuh server Reverb berjalan.
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# PRODUKSI: database (+ jalankan queue worker). 'sync' hanya untuk dev.
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# Gateway OTP / Notifikasi WhatsApp
#   driver: log | fonnte | wablas | cloud | email
# ============================================================
NOTIFICATION_DRIVER=log
NOTIFICATION_FALLBACK_EMAIL=false
# Fonnte (https://fonnte.com) — paling praktis
FONNTE_TOKEN=
# Wablas (https://wablas.com)
WABLAS_TOKEN=
WABLAS_DOMAIN=https://solo.wablas.com
# WhatsApp Cloud API resmi Meta
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Token verifikasi webhook inbound (WAJIB di-set; webhook fail-closed bila kosong)
NOTIFICATION_WEBHOOK_TOKEN=

# PIN e-sign Operator Pekon (Kepala Pekon) — WAJIB diganti di produksi
ESIGN_PEKON_PIN=

# ============================================================
# Sanctum (token API mobile)
# ============================================================
SANCTUM_EXPIRATION=43200

# ============================================================
# Broadcasting Reverb (real-time antrian)
# ============================================================
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ============================================================
# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@example.com"
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# ============================================================
# Integrasi eksternal (default 'mock' — tidak memanggil API nyata)
# ============================================================
DUKCAPIL_DRIVER=mock
DUKCAPIL_BASE_URL=
DUKCAPIL_TOKEN=
DTSEN_DRIVER=mock
DTSEN_BASE_URL=
DTSEN_TOKEN=
LAPOR_DRIVER=mock
LAPOR_BASE_URL=
LAPOR_TOKEN=
LAPOR_INSTANSI_ID=
# BSrE BSSN — Tanda Tangan Elektronik tersertifikasi
BSRE_DRIVER=mock
BSRE_ENABLED=false
BSRE_BASE_URL=
BSRE_USER=
BSRE_PASS=
BSRE_PASSPHRASE=

# ============================================================
# Penyimpanan berkas sensitif (disk 'secure')
#   driver: local | minio
# ============================================================
SECURE_DISK_DRIVER=local
MINIO_KEY=
MINIO_SECRET=
MINIO_REGION=us-east-1
MINIO_BUCKET=
MINIO_ENDPOINT=
MINIO_URL=

# ============================================================
# Tenant (single-tenant untuk Pringsewu)
# ============================================================
TENANT_MODE=single
TENANT_ID=
TENANT_NAME="Dinas Sosial Kabupaten Pringsewu"

# Email penerima laporan retensi data (PDP)
PDP_REPORT_EMAIL=

# Peran kontainer (Docker entrypoint): web | queue | scheduler
CONTAINER_ROLE=web

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
